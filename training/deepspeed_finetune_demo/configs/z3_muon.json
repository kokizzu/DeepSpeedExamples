{
    "train_batch_size": 8,
    "bf16": { "enabled": true },
    "zero_optimization": {
      "stage": 3,
      "reduce_scatter": false
    },
    "optimizer": {
      "type": "Muon",
      "params": {
        "muon_lr": 1e-3,
        "adam_lr": 2e-5,
        "momentum": 0.95,
        "betas": [0.9, 0.999],
        "eps": 1e-8,
        "weight_decay": 0.01
      }
    },
    "gradient_accumulation_steps": 1,
    "gradient_clipping": 1.0,
    "zero_allow_untested_optimizer": true
}
